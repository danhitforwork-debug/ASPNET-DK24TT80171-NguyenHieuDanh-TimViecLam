<?xml version="1.0"?>
<configuration>
 <connectionStrings>
	 <add name="JobDb"
		connectionString="Data Source=.;Initial Catalog=JobRecruitmentDb;Integrated Security=True"
		providerName="System.Data.SqlClient"/>
 </connectionStrings>
 <system.web>
  <compilation debug="true" targetFramework="4.8" />
  <httpRuntime targetFramework="4.8" maxRequestLength="10240" />
 </system.web>
</configuration>
